# ─── Arc Testnet ──────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# ─── Deployer ─────────────────────────────────────────────────
# This wallet deploys contracts and is an authorized credit recorder
DEPLOYER_PRIVATE_KEY=0x

# ─── Circle APIs ──────────────────────────────────────────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# ─── Agent Private Keys ───────────────────────────────────────
DATA_AGENT_PRIVATE_KEY=0x
COMPUTE_AGENT_PRIVATE_KEY=0x
ANALYST_AGENT_PRIVATE_KEY=0x
LENDER_AGENT_PRIVATE_KEY=0x
AUDITOR_AGENT_PRIVATE_KEY=0x

# ─── Contract Addresses (populated by deploy.js → deployments.json) ─
IDENTITY_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
VALIDATION_REGISTRY_ADDRESS=
CREDIT_SCORE_ADDRESS=
MOCK_USDC_ADDRESS=
LENDING_POOL_ADDRESS=

# ─── Agent IDs (populated by register-agents.ts → agent-ids.json / .env) ─
DATA_AGENT_ID=
COMPUTE_AGENT_ID=
ANALYST_AGENT_ID=
LENDER_AGENT_ID=
AUDITOR_AGENT_ID=

# ─── Service Ports ────────────────────────────────────────────
DATA_AGENT_PORT=3001
COMPUTE_AGENT_PORT=3002
ANALYST_AGENT_PORT=3003
LENDER_AGENT_PORT=3005
AUDITOR_AGENT_PORT=3006
DASHBOARD_PORT=3004

# ─── Demo loop (AnalystAgent + start-demo.sh) ─────────────────
DEMO_ITERATIONS=8
DEMO_ITERATION_DELAY_MS=4000
DEMO_LOAN_AMOUNT_USDC=10
# Optional: zero-based iteration index to repay (default = iterations - 2)
# DEMO_REPAY_ZERO_BASED_INDEX=6
LENDER_DEPOSIT_USDC=200
HEALTH_WAIT_TIMEOUT=120
